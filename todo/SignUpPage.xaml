<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo.SignUpPage"
             Title="Sign Up">

    <VerticalStackLayout Padding="30" Spacing="15">

        <Button Text="Already have an account? Sign In"
        BackgroundColor="Transparent"
        TextColor="Blue"
        Clicked="GoToSignIn_Clicked"/>
        
        <Entry x:Name="FirstNameEntry" Placeholder="First Name"/>
        <Entry x:Name="LastNameEntry" Placeholder="Last Name"/>
        <Entry x:Name="EmailEntry" Placeholder="Email"/>
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True"/>
        <Button Text="Sign Up" Clicked="SignUpButton_Clicked"/>
        <Label x:Name="MessageLabel" TextColor="Red"/>

        <!-- Navigation to Sign In -->
       

    </VerticalStackLayout>
</ContentPage>